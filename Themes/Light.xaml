<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="App.Bg"           Color="#F3F3F3"/>
    <SolidColorBrush x:Key="Panel.Bg"         Color="#F5F5F5"/>
    <SolidColorBrush x:Key="Surface.Bg"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Input.Bg"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Toolbar.Bg"       Color="#F0F0F0"/>
    <SolidColorBrush x:Key="Info.Bg"          Color="#EBEBEB"/>
    <SolidColorBrush x:Key="Subtle.Bg"        Color="#E8E8E8"/>
    <SolidColorBrush x:Key="Subtle.Border"    Color="#D0D0D0"/>
    <SolidColorBrush x:Key="Splitter.Bg"      Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TabBar.Bg"        Color="#F0F0F0"/>
    <SolidColorBrush x:Key="Journal.Hdr.Bg"   Color="#EBEBEB"/>
    <SolidColorBrush x:Key="Phone.Bg"         Color="#FAFAFA"/>
    <SolidColorBrush x:Key="Debug.Bg"         Color="#F6F8FA"/>
    <SolidColorBrush x:Key="Debug.Border"     Color="#D0D0D0"/>
    <SolidColorBrush x:Key="ActionStrip.Bg"   Color="#F0F0F0" Opacity="0.8"/>
    <SolidColorBrush x:Key="Setup.Bg"         Color="#F8F8F8" Opacity="0.94"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Text.Primary"     Color="#1A1A1A"/>
    <SolidColorBrush x:Key="Text.Secondary"   Color="#6A6A6A"/>
    <SolidColorBrush x:Key="Text.Muted"       Color="#777777"/>
    <SolidColorBrush x:Key="Text.Label"       Color="#888888"/>
    <SolidColorBrush x:Key="Text.Hint"        Color="#999999"/>
    <SolidColorBrush x:Key="Text.SectionHdr"  Color="#666666"/>

    <!-- Borders / separators -->
    <SolidColorBrush x:Key="Border.Primary"   Color="#C0C0C0"/>
    <SolidColorBrush x:Key="Border.Secondary" Color="#D8D8D8"/>
    <SolidColorBrush x:Key="Sep.Dark"         Color="#D0D0D0"/>
    <SolidColorBrush x:Key="Sep.Light"        Color="#D8D8D8"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="Btn.Bg"           Color="#E8E8E8"/>
    <SolidColorBrush x:Key="Btn.Fg"           Color="#1A1A1A"/>
    <SolidColorBrush x:Key="Btn.Border"       Color="#C0C0C0"/>
    <SolidColorBrush x:Key="Btn.Hover.Bg"     Color="#D8D8D8"/>
    <SolidColorBrush x:Key="Btn.Hover.Border" Color="#909090"/>
    <SolidColorBrush x:Key="Btn.Press.Bg"     Color="#C0C0C0"/>
    <SolidColorBrush x:Key="Btn.Press.Border" Color="#A0A0A0"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="CB.Popup.Bg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CB.Item.Hover"    Color="#E8E8E8"/>
    <SolidColorBrush x:Key="CB.Item.Sel"      Color="#CCE4FF"/>
    <SolidColorBrush x:Key="CB.Chevron"       Color="#666666"/>

    <!-- Tab buttons -->
    <SolidColorBrush x:Key="Tab.Hover.Bg"     Color="#E0E0E0"/>
    <SolidColorBrush x:Key="Tab.Press.Bg"     Color="#D0D0D0"/>

    <!-- ProgressBar track -->
    <SolidColorBrush x:Key="PB.Bg"            Color="#D8D8D8"/>

    <!-- Status panel -->
    <SolidColorBrush x:Key="Status.Sep"       Color="#D8D8D8"/>
    <SolidColorBrush x:Key="Status.Lbl"       Color="#555555"/>
    <SolidColorBrush x:Key="Status.Val"       Color="#888888"/>
    <SolidColorBrush x:Key="Status.Lbl.H"     Color="#999999"/>
    <SolidColorBrush x:Key="Status.Val.H"     Color="#BBBBBB"/>

    <!-- Journal -->
    <SolidColorBrush x:Key="Journal.Chevron"  Color="#777777"/>
    <SolidColorBrush x:Key="Journal.Empty"    Color="#999999"/>

    <!-- Inventory -->
    <SolidColorBrush x:Key="Inv.Section"      Color="#777777"/>
    <SolidColorBrush x:Key="Inv.Empty"        Color="#999999"/>
    <SolidColorBrush x:Key="Inv.Count"        Color="#888888"/>

    <!-- Mods panel -->
    <SolidColorBrush x:Key="Mod.Author"       Color="#777777"/>
    <SolidColorBrush x:Key="Mod.Hint"         Color="#999999"/>

</ResourceDictionary>
