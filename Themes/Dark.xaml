<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="App.Bg"           Color="#1C1C1C"/>
    <SolidColorBrush x:Key="Panel.Bg"         Color="#191919"/>
    <SolidColorBrush x:Key="Surface.Bg"       Color="#272727"/>
    <SolidColorBrush x:Key="Input.Bg"         Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Toolbar.Bg"       Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Info.Bg"          Color="#202020"/>
    <SolidColorBrush x:Key="Subtle.Bg"        Color="#0A0A0A"/>
    <SolidColorBrush x:Key="Subtle.Border"    Color="#222222"/>
    <SolidColorBrush x:Key="Splitter.Bg"      Color="#2A2A2A"/>
    <SolidColorBrush x:Key="TabBar.Bg"        Color="#1C1C1C"/>
    <SolidColorBrush x:Key="Journal.Hdr.Bg"   Color="#222222"/>
    <SolidColorBrush x:Key="Phone.Bg"         Color="#111111"/>
    <SolidColorBrush x:Key="Debug.Bg"         Color="#0D1117"/>
    <SolidColorBrush x:Key="Debug.Border"     Color="#30363D"/>
    <!-- ActionStrip uses 80% opacity over App.Bg — approximated as solid with alpha -->
    <SolidColorBrush x:Key="ActionStrip.Bg"   Color="#1C1C1C" Opacity="0.8"/>
    <SolidColorBrush x:Key="Setup.Bg"         Color="#111111" Opacity="0.94"/>

    <!-- Text -->
    <SolidColorBrush x:Key="Text.Primary"     Color="#E8E8E8"/>
    <SolidColorBrush x:Key="Text.Secondary"   Color="#8A8A8A"/>
    <SolidColorBrush x:Key="Text.Muted"       Color="#6A6A6A"/>
    <SolidColorBrush x:Key="Text.Label"       Color="#AAAAAA"/>
    <SolidColorBrush x:Key="Text.Hint"        Color="#555555"/>
    <SolidColorBrush x:Key="Text.SectionHdr"  Color="#888888"/>

    <!-- Borders / separators -->
    <SolidColorBrush x:Key="Border.Primary"   Color="#454545"/>
    <SolidColorBrush x:Key="Border.Secondary" Color="#2E2E2E"/>
    <SolidColorBrush x:Key="Sep.Dark"         Color="#3A3A3A"/>
    <SolidColorBrush x:Key="Sep.Light"        Color="#2A2A2A"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="Btn.Bg"           Color="#2D2D2D"/>
    <SolidColorBrush x:Key="Btn.Fg"           Color="#E8E8E8"/>
    <SolidColorBrush x:Key="Btn.Border"       Color="#454545"/>
    <SolidColorBrush x:Key="Btn.Hover.Bg"     Color="#3C3C3C"/>
    <SolidColorBrush x:Key="Btn.Hover.Border" Color="#606060"/>
    <SolidColorBrush x:Key="Btn.Press.Bg"     Color="#1A1A1A"/>
    <SolidColorBrush x:Key="Btn.Press.Border" Color="#404040"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="CB.Popup.Bg"      Color="#1E1E1E"/>
    <SolidColorBrush x:Key="CB.Item.Hover"    Color="#333333"/>
    <SolidColorBrush x:Key="CB.Item.Sel"      Color="#2A2A2A"/>
    <SolidColorBrush x:Key="CB.Chevron"       Color="#888888"/>

    <!-- Tab buttons -->
    <SolidColorBrush x:Key="Tab.Hover.Bg"     Color="#252525"/>
    <SolidColorBrush x:Key="Tab.Press.Bg"     Color="#1C1C1C"/>

    <!-- ProgressBar track -->
    <SolidColorBrush x:Key="PB.Bg"            Color="#3A3A3A"/>

    <!-- Status panel -->
    <SolidColorBrush x:Key="Status.Sep"       Color="#2A2A2A"/>
    <SolidColorBrush x:Key="Status.Lbl"       Color="#ABABAB"/>
    <SolidColorBrush x:Key="Status.Val"       Color="#666666"/>
    <SolidColorBrush x:Key="Status.Lbl.H"     Color="#666666"/>
    <SolidColorBrush x:Key="Status.Val.H"     Color="#444444"/>

    <!-- Journal -->
    <SolidColorBrush x:Key="Journal.Chevron"  Color="#666666"/>
    <SolidColorBrush x:Key="Journal.Empty"    Color="#444444"/>

    <!-- Inventory -->
    <SolidColorBrush x:Key="Inv.Section"      Color="#666666"/>
    <SolidColorBrush x:Key="Inv.Empty"        Color="#444444"/>
    <SolidColorBrush x:Key="Inv.Count"        Color="#606060"/>

    <!-- Mods panel -->
    <SolidColorBrush x:Key="Mod.Author"       Color="#888888"/>
    <SolidColorBrush x:Key="Mod.Hint"         Color="#555555"/>

</ResourceDictionary>
