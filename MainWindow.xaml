<Window x:Class="ACVN.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ACVN"
        mc:Ignorable="d"
        Title="ACVN" Height="900" Width="1200"
        Background="{DynamicResource App.Bg}"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Base button: rounded corners, hover/press states -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource Btn.Bg}"/>
            <Setter Property="Foreground"       Value="{DynamicResource Btn.Fg}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource Btn.Border}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,5,10,5"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Hover/pressed in Style.Triggers so DynamicResource works -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="{DynamicResource Btn.Hover.Bg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource Btn.Hover.Border}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background"  Value="{DynamicResource Btn.Press.Bg}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource Btn.Press.Border}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Default style for all Buttons -->
        <Style TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}"/>

        <!-- Toolbar control buttons -->
        <Style x:Key="ControlButtonStyle" TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Height"   Value="36"/>
            <Setter Property="Padding"  Value="12,0,12,0"/>
        </Style>

        <!-- Icon-only button -->
        <Style x:Key="IconButtonStyle" TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Width"           Value="36"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>

        <!-- Attribute progress bars -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background"      Value="{DynamicResource PB.Bg}"/>
            <Setter Property="Foreground"      Value="#0078D4"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="6"/>
        </Style>

        <!-- CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{DynamicResource Text.Primary}"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Margin"      Value="0,4,0,4"/>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource Input.Bg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource Text.Primary}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Border.Primary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4,6,4"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource Text.Primary}"/>
        </Style>

        <!-- ComboBox — full ControlTemplate so system theme cannot override colours -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"            Value="{DynamicResource Input.Bg}"/>
            <Setter Property="Foreground"            Value="{DynamicResource Text.Primary}"/>
            <Setter Property="BorderBrush"           Value="{DynamicResource Border.Primary}"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="FontFamily"            Value="Segoe UI"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="Padding"               Value="6,4,6,4"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels"   Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="&#x25BE;"
                                               Foreground="{DynamicResource CB.Chevron}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen,
                                       RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PopupAnimation="None">
                                <Border Background="{DynamicResource CB.Popup.Bg}"
                                        BorderBrush="{DynamicResource Border.Primary}"
                                        BorderThickness="1"
                                        MaxHeight="300">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Btn.Hover.Border}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="{DynamicResource Input.Bg}"/>
            <Setter Property="Foreground"  Value="{DynamicResource Text.Primary}"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CB.Item.Hover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CB.Item.Sel}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Tab bar buttons -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource Text.Muted}"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Tab.Hover.Bg}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Tab.Press.Bg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid x:Name="mainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500*" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="300*" MinWidth="160"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             LEFT COLUMN  –  Story content + action strip
        ════════════════════════════════════════════════════════════ -->
        <WebBrowser x:Name="mainContent"
                    Grid.Row="0" Grid.Column="0"
                    Margin="0,0,0,46"
                    Panel.ZIndex="200"/>

        <!-- Semi-transparent action-button strip overlaying the content bottom -->
        <Border Grid.Row="0" Grid.Column="0"
                VerticalAlignment="Bottom"
                Height="46"
                Background="{DynamicResource ActionStrip.Bg}"
                BorderBrush="{DynamicResource Border.Secondary}" BorderThickness="0,1,0,0"
                Panel.ZIndex="1000">
            <StackPanel x:Name="actionStack"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="8,0,8,0"/>
        </Border>

        <!-- Draggable column splitter -->
        <GridSplitter x:Name="colSplitter" Grid.Column="1" Grid.Row="0"
                      Width="5" HorizontalAlignment="Stretch"
                      Background="{DynamicResource Splitter.Bg}" Cursor="SizeWE"
                      Panel.ZIndex="500"/>

        <!-- ═══════════════════════════════════════════════════════════
             RIGHT COLUMN  –  Media · Player info · Tabs · Debug
        ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="rightPanel" Grid.Column="2" Grid.Row="0"
              Background="{DynamicResource Panel.Bg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- media -->
                <RowDefinition Height="Auto"/>  <!-- player info -->
                <RowDefinition Height="52"/>    <!-- tab button bar -->
                <RowDefinition Height="*"/>     <!-- tab content -->
                <RowDefinition Height="Auto"/>  <!-- debug -->
            </Grid.RowDefinitions>

            <!-- Media + transparent click-overlay + fullscreen hint -->
            <Grid Grid.Row="0">
                <Image x:Name="mainImage"
                       HorizontalAlignment="Stretch"
                       MaxHeight="280" VerticalAlignment="Top"
                       Stretch="Uniform"
                       Visibility="Collapsed"/>
                <MediaElement x:Name="mainMedia"
                              HorizontalAlignment="Stretch"
                              MaxHeight="280" VerticalAlignment="Top"
                              LoadedBehavior="Manual"
                              MediaOpened="mainMedia_MediaOpened"
                              MediaEnded="mainMedia_MediaEnded"
                              Visibility="Collapsed"/>
                <Border Background="Transparent"
                        MaxHeight="280" VerticalAlignment="Top"
                        Cursor="Hand" Panel.ZIndex="50"
                        MouseLeftButtonUp="mediaArea_Click"/>
                <Button x:Name="mediaFullscreenHint"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,6,6,0" Panel.ZIndex="60"
                        Background="#88000000" BorderBrush="Transparent"
                        Padding="5" Cursor="Hand"
                        Visibility="Collapsed"
                        Click="mediaArea_FullscreenBtn_Click"
                        ToolTip="Vollbild">
                    <TextBlock Text="&#xE740;" FontFamily="Segoe MDL2 Assets"
                               FontSize="12" Foreground="#CCCCCC"/>
                </Button>
            </Grid>

            <!-- Player info bar -->
            <Border Grid.Row="1"
                    Background="{DynamicResource Info.Bg}"
                    BorderBrush="{DynamicResource Border.Secondary}" BorderThickness="0,1,0,1"
                    Padding="10,7,10,7">
                <Grid>
                    <TextBlock x:Name="playerNameText" Text="Name"
                               HorizontalAlignment="Left" VerticalAlignment="Center"
                               Foreground="{DynamicResource Text.Primary}"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="gameTimeText" Text="00:00"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="{DynamicResource Text.Secondary}" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Tab button bar -->
            <Border Grid.Row="2"
                    Background="{DynamicResource TabBar.Bg}"
                    BorderBrush="{DynamicResource Border.Secondary}" BorderThickness="0,0,0,1">
                <UniformGrid Columns="6">
                    <Button x:Name="tabBtnStatus"    Style="{StaticResource TabButtonStyle}" Click="tabBtnStatus_Click">
                        <StackPanel Margin="0,6,0,6">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="tbTabStatus" FontSize="9" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="tabBtnPhone"     Style="{StaticResource TabButtonStyle}" Click="tabBtnPhone_Click">
                        <StackPanel Margin="0,6,0,6">
                            <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="tbTabPhone" FontSize="9" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="tabBtnInventory" Style="{StaticResource TabButtonStyle}" Click="tabBtnInventory_Click">
                        <StackPanel Margin="0,6,0,6">
                            <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="tbTabInventory" FontSize="9" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="tabBtnJournal"   Style="{StaticResource TabButtonStyle}" Click="tabBtnJournal_Click">
                        <StackPanel Margin="0,6,0,6">
                            <TextBlock Text="&#xE8A4;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="tbTabJournal" FontSize="9" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="tabBtnRelationships" Style="{StaticResource TabButtonStyle}" Click="tabBtnRelationships_Click">
                        <StackPanel Margin="0,6,0,6">
                            <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="tbTabContacts" FontSize="9" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="tabBtnGameSettings" Style="{StaticResource TabButtonStyle}" Click="tabBtnGameSettings_Click">
                        <StackPanel Margin="0,6,0,6">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="tbTabSettings" FontSize="9" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </Border>

            <!-- Tab content area (one panel visible at a time) -->
            <Grid Grid.Row="3">

                <!-- Status panel (default) -->
                <ScrollViewer x:Name="panelStatus" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="statusStack" Margin="10,10,10,4"/>
                </ScrollViewer>

                <!-- Phone panel – home screen -->
                <ScrollViewer x:Name="panelPhone" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel HorizontalAlignment="Center" Margin="12,20,12,12">
                        <Button x:Name="phoneAppTelefon" Click="phoneApp_Click" Tag="telefon"
                                Width="80" Height="80" Margin="8" Style="{StaticResource ModernButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" Foreground="#4CAF50"/>
                                <TextBlock x:Name="tbPhoneTelefon" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="phoneAppNachrichten" Click="phoneApp_Click" Tag="nachrichten"
                                Width="80" Height="80" Margin="8" Style="{StaticResource ModernButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" Foreground="#2196F3"/>
                                <TextBlock x:Name="tbPhoneNachrichten" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="phoneAppKamera" Click="phoneApp_Click" Tag="kamera"
                                Width="80" Height="80" Margin="8" Style="{StaticResource ModernButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" Foreground="#FF9800"/>
                                <TextBlock x:Name="tbPhoneKamera" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="phoneAppMedien" Click="phoneApp_Click" Tag="medien"
                                Width="80" Height="80" Margin="8" Style="{StaticResource ModernButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" Foreground="#9C27B0"/>
                                <TextBlock x:Name="tbPhoneMedien" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="phoneAppInstagram" Click="phoneApp_Click" Tag="instagram"
                                Width="80" Height="80" Margin="8" Style="{StaticResource ModernButtonStyle}">
                            <StackPanel>
                                <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" FontSize="26"
                                           HorizontalAlignment="Center" Foreground="#E91E63"/>
                                <TextBlock x:Name="tbPhoneInstagram" FontSize="10" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </ScrollViewer>

                <!-- Inventory panel -->
                <ScrollViewer x:Name="panelInventory" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="inventoryStack" Margin="10,10,10,4"/>
                </ScrollViewer>

                <!-- Journal panel -->
                <ScrollViewer x:Name="panelJournal" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="journalStack" Margin="10,10,10,4"/>
                </ScrollViewer>

                <!-- Relationships panel -->
                <ScrollViewer x:Name="panelRelationships" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="relationshipsStack" Margin="10,10,10,4"/>
                </ScrollViewer>

                <!-- Game-Settings panel -->
                <ScrollViewer x:Name="panelGameSettings" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,10,12,10">

                        <!-- Section: Display -->
                        <TextBlock x:Name="tbSettingsDisplayHeader"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.SectionHdr}"
                                   Margin="0,0,0,6"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="tbSettingShowHidden"
                                       Grid.Column="0"
                                       Foreground="{DynamicResource Text.Primary}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <CheckBox x:Name="showHiddenToggle"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Checked="showHiddenToggle_Changed"
                                      Unchecked="showHiddenToggle_Changed"/>
                        </Grid>

                        <Rectangle Height="1" Fill="{DynamicResource Sep.Light}" Margin="0,12,0,12"/>

                        <!-- Section: Mods -->
                        <TextBlock x:Name="tbSettingsModsHeader"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.SectionHdr}"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="tbSettingsModsHint"
                                   FontSize="11" Foreground="{DynamicResource Text.Muted}"
                                   TextWrapping="Wrap" Margin="0,0,0,4"
                                   Visibility="Collapsed"/>
                        <StackPanel x:Name="modsSettingsStack"/>

                    </StackPanel>
                </ScrollViewer>

            </Grid>

            <!-- Debug panel (visible only when debug is on) -->
            <Border x:Name="debugPanel" Grid.Row="4"
                    Background="{DynamicResource Debug.Bg}"
                    BorderBrush="{DynamicResource Debug.Border}" BorderThickness="0,1,0,0"
                    Padding="8,5,8,5" Visibility="Collapsed">
                <TextBlock x:Name="debugText"
                           FontSize="10" FontFamily="Consolas"
                           TextWrapping="Wrap" Foreground="#FF6B6B"/>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             BOTTOM TOOLBAR  –  Room nav  |  Controls
        ════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.ColumnSpan="3"
                Background="{DynamicResource Toolbar.Bg}"
                BorderBrush="{DynamicResource Border.Secondary}" BorderThickness="0,1,0,0">
            <Grid Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="roomStack"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button x:Name="quickSaveButton" Click="quickSaveButton_Click"
                            Style="{StaticResource ControlButtonStyle}"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="tbQuickSave" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="quickLoadButton" Click="quickLoadButton_Click"
                            Style="{StaticResource ControlButtonStyle}"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="tbQuickLoad" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="{DynamicResource Sep.Dark}" Margin="4,0,4,0"/>

                    <Button x:Name="saveButton" Click="saveButton_Click"
                            Style="{StaticResource ControlButtonStyle}"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="tbSave" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="loadButton" Click="loadButton_Click"
                            Style="{StaticResource ControlButtonStyle}"
                            Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="tbLoad" Margin="7,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Height="20" Fill="{DynamicResource Sep.Dark}" Margin="4,0,4,0"/>

                    <Button x:Name="backButton" Click="backButton_Click"
                            Style="{StaticResource IconButtonStyle}"
                            IsEnabled="False"
                            Margin="0,0,4,0">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                    </Button>

                    <Button x:Name="settingsButton" Click="settingsButton_Click"
                            Style="{StaticResource IconButtonStyle}">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             SETTINGS FLYOUT  –  floats above toolbar
        ════════════════════════════════════════════════════════════ -->
        <Border x:Name="settingsPanel"
                Grid.Row="0" Grid.RowSpan="2"
                Grid.Column="0" Grid.ColumnSpan="3"
                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,8,60"
                MinWidth="250"
                Background="{DynamicResource Surface.Bg}"
                BorderBrush="{DynamicResource Border.Primary}" BorderThickness="1"
                CornerRadius="8"
                Padding="16,14,16,14"
                Panel.ZIndex="3000"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="90"
                                  ShadowDepth="6" BlurRadius="16" Opacity="0.55"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="tbSettingsTitle"
                           FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource Text.Primary}" Margin="0,0,0,12"/>
                <CheckBox x:Name="debugToggle"
                          Checked="debugToggle_Changed"
                          Unchecked="debugToggle_Changed"/>
                <CheckBox x:Name="videoAutoplayToggle"
                          IsChecked="True" Margin="0,4,0,0"
                          Checked="videoAutoplay_Changed"
                          Unchecked="videoAutoplay_Changed"/>

                <Rectangle Height="1" Fill="{DynamicResource Sep.Dark}" Margin="0,12,0,6"/>

                <!-- Volume -->
                <Grid Margin="0,0,0,4">
                    <TextBlock x:Name="tbVolLabel" Foreground="{DynamicResource Text.Label}"
                               FontSize="12" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <TextBlock x:Name="volumeLabel" Text="80%"
                               Foreground="{DynamicResource Text.Muted}" FontSize="11"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <Slider x:Name="volumeSlider" Minimum="0" Maximum="100" Value="80"
                        ValueChanged="volumeSlider_Changed" Margin="0,0,0,4"/>

                <Rectangle Height="1" Fill="{DynamicResource Sep.Dark}" Margin="0,8,0,6"/>

                <!-- Language -->
                <TextBlock x:Name="tbLangLabel"
                           Foreground="{DynamicResource Text.Label}" FontSize="12" Margin="0,0,0,4"/>
                <ComboBox x:Name="langDropdown" SelectionChanged="langDropdown_Changed"
                          Margin="0,0,0,4"/>

                <Rectangle Height="1" Fill="{DynamicResource Sep.Dark}" Margin="0,8,0,6"/>

                <!-- Theme -->
                <TextBlock x:Name="tbThemeLabel"
                           Foreground="{DynamicResource Text.Label}" FontSize="12" Margin="0,0,0,4"/>
                <ComboBox x:Name="themeDropdown" SelectionChanged="themeDropdown_Changed"
                          Margin="0,0,0,4"/>

                <Rectangle Height="1" Fill="{DynamicResource Sep.Dark}" Margin="0,8,0,6"/>

                <!-- Cheats -->
                <Button x:Name="cheatBtn" Click="cheatButton_Click"
                        HorizontalAlignment="Stretch"
                        Margin="0,2,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbCheatBtn" Text="Cheats" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Rectangle Height="1" Fill="{DynamicResource Sep.Dark}" Margin="0,2,0,6"/>

                <Button x:Name="restartBtn" Click="restartButton_Click"
                        HorizontalAlignment="Stretch"
                        Foreground="#FF6B6B"
                        Margin="0,2,0,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbSettingsRestart" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Rectangle Height="1" Fill="{DynamicResource Sep.Dark}" Margin="0,0,0,8"/>
                <Button x:Name="settingsBackButton" Click="backButton_Click"
                        IsEnabled="False"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="tbSettingsBack" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             CHEAT OVERLAY
        ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="cheatOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              Grid.Column="0" Grid.ColumnSpan="3"
              Panel.ZIndex="5000"
              Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="Black" Opacity="0.55"/>
            </Grid.Background>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="560" MaxWidth="740"
                    MaxHeight="680"
                    Background="{DynamicResource Surface.Bg}"
                    BorderBrush="{DynamicResource Border.Primary}" BorderThickness="1"
                    CornerRadius="10"
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="90"
                                      ShadowDepth="8" BlurRadius="24" Opacity="0.6"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource Subtle.Bg}"
                            BorderBrush="{DynamicResource Subtle.Border}" BorderThickness="0,0,0,1"
                            CornerRadius="10,10,0,0"
                            Padding="20,0,12,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Text.Primary}"
                                           Margin="0,0,8,0"/>
                                <TextBlock Text="Cheats" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text.Primary}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button x:Name="cheatCloseBtn" Click="cheatCloseButton_Click"
                                    Style="{StaticResource IconButtonStyle}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Scrollable content -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="20,16,20,16">
                        <StackPanel x:Name="cheatStack"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             CHARACTER SETUP OVERLAY
        ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="setupOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              Grid.Column="0" Grid.ColumnSpan="3"
              Background="{DynamicResource Setup.Bg}"
              Panel.ZIndex="11000"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="setupStack"
                            MaxWidth="520" HorizontalAlignment="Center"
                            Margin="40,40,40,20"/>
            </ScrollViewer>

            <Border Grid.Row="1"
                    Background="{DynamicResource Subtle.Bg}"
                    BorderBrush="{DynamicResource Subtle.Border}" BorderThickness="0,1,0,0"
                    Padding="20,12,20,12">
                <Button x:Name="setupContinueBtn" Click="setupContinueBtn_Click"
                        HorizontalAlignment="Right"
                        Height="38" Padding="24,0,24,0"
                        Background="#0078D4" BorderBrush="#0078D4"
                        Foreground="White"/>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             PHONE APP OVERLAY
        ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="phoneAppOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              Grid.Column="0" Grid.ColumnSpan="3"
              Background="{DynamicResource Phone.Bg}"
              Panel.ZIndex="7000"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Background="{DynamicResource Subtle.Bg}"
                    BorderBrush="{DynamicResource Subtle.Border}" BorderThickness="0,0,0,1">
                <Grid Margin="8,0,8,0">
                    <Button x:Name="phoneAppBackBtn" Click="phoneAppBackBtn_Click"
                            Style="{StaticResource IconButtonStyle}"
                            HorizontalAlignment="Left" ToolTip="Zurück">
                        <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                    </Button>
                    <TextBlock x:Name="phoneAppTitle"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource Text.Primary}"
                               FontSize="14" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <WebBrowser x:Name="phoneContentBrowser" Grid.Row="1" Visibility="Collapsed"/>

            <!-- Calling / SMS state panel -->
            <Grid x:Name="phoneStatusPanel" Grid.Row="1" Visibility="Collapsed"
                  Background="{DynamicResource Phone.Bg}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image x:Name="phoneCallerImage" Width="80" Height="80"
                           Margin="0,0,0,16"
                           Stretch="UniformToFill">
                        <Image.Clip>
                            <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                        </Image.Clip>
                    </Image>
                    <TextBlock x:Name="phoneStatusName"
                               Foreground="{DynamicResource Text.Primary}"
                               FontSize="20" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="phoneStatusText"
                               Foreground="{DynamicResource Text.Secondary}" FontSize="14"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Camera view (always dark) -->
            <Grid x:Name="phoneCameraPanel" Grid.Row="1" Visibility="Collapsed"
                  Background="#000000">
                <Image x:Name="phoneCameraPreview"
                       Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel x:Name="phoneCameraHint"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock x:Name="phoneCameraHintIcon"
                               Text="&#xE722;" FontFamily="Segoe MDL2 Assets"
                               FontSize="40" Foreground="#444444"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="phoneCameraHintText"
                               Foreground="#555555" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
                <Button x:Name="phoneCaptureBtn" Click="phoneCaptureBtn_Click"
                        Width="64" Height="64"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,24"
                        Background="#FFFFFF" BorderBrush="#CCCCCC" BorderThickness="4"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Ellipse x:Name="circle"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="{TemplateBinding BorderThickness}"
                                     Width="64" Height="64"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="circle" Property="Fill" Value="#EEEEEE"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="circle" Property="Fill" Value="#CCCCCC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Media gallery -->
            <ScrollViewer x:Name="phoneMediaGalleryScroll" Grid.Row="1" Visibility="Collapsed"
                          Background="{DynamicResource Subtle.Bg}" VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="phoneMediaGallery" Margin="8"/>
            </ScrollViewer>

            <!-- Instagram placeholder -->
            <Border x:Name="phoneInstagramPanel" Grid.Row="1" Visibility="Collapsed"
                    Background="{DynamicResource Phone.Bg}">
                <TextBlock Text="Instagram" Foreground="{DynamicResource Text.Muted}" FontSize="24"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Action strip -->
            <Border Grid.Row="2" Background="{DynamicResource Subtle.Bg}"
                    BorderBrush="{DynamicResource Subtle.Border}" BorderThickness="0,1,0,0"
                    Padding="8,4,8,4">
                <StackPanel x:Name="phoneActionStack" Orientation="Horizontal"
                            VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             MEDIA MODAL OVERLAY  –  always black regardless of theme
        ════════════════════════════════════════════════════════════ -->
        <Grid x:Name="mediaModalOverlay"
              Grid.Row="0" Grid.RowSpan="2"
              Grid.Column="0" Grid.ColumnSpan="3"
              Background="#EE000000"
              Panel.ZIndex="8500"
              Visibility="Collapsed"
              MouseLeftButtonDown="mediaModalOverlay_Click">
            <Image x:Name="mediaModalImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
            <MediaElement x:Name="mediaModalVideo"
                          LoadedBehavior="Manual"
                          Stretch="Uniform"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          MediaOpened="mediaModalVideo_MediaOpened"
                          MediaEnded="mediaModalVideo_MediaEnded"
                          Visibility="Collapsed"/>
            <TextBlock x:Name="tbMediaCloseHint"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       Margin="0,14,0,0"
                       Foreground="#55FFFFFF" FontSize="11"
                       IsHitTestVisible="False"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             WARDROBE OVERLAY
        ════════════════════════════════════════════════════════════ -->
        <Border x:Name="wardrobeOverlay"
                Grid.Row="0" Grid.RowSpan="2"
                Grid.Column="0" Grid.ColumnSpan="3"
                Background="#BB000000" Panel.ZIndex="9500"
                Visibility="Collapsed"
                MouseLeftButtonDown="wardrobeOverlay_Click">
            <Border x:Name="wardrobeCard"
                    Background="{DynamicResource Surface.Bg}"
                    BorderBrush="{DynamicResource Border.Primary}" BorderThickness="1"
                    CornerRadius="10" Padding="20"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MouseLeftButtonDown="wardrobeCard_StopPropagation">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="90"
                                      ShadowDepth="8" BlurRadius="20" Opacity="0.7"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock x:Name="tbWardrobeTitle"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button Content="&#x2715;" Click="wardrobeClose_Click"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="Transparent" Foreground="{DynamicResource Text.Secondary}"
                                BorderBrush="Transparent" FontSize="14"
                                Cursor="Hand" Padding="4,0,4,0"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="wardrobeStack" Margin="0,0,8,0"/>
                    </ScrollViewer>
                    <TextBlock x:Name="wardrobeStateLabel"
                               Grid.Row="2"
                               Margin="0,12,0,0"
                               FontSize="11" Foreground="{DynamicResource Text.Muted}"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ITEM INFO OVERLAY
        ════════════════════════════════════════════════════════════ -->
        <Border x:Name="itemInfoOverlay"
                Grid.Row="0" Grid.RowSpan="2"
                Grid.Column="0" Grid.ColumnSpan="3"
                Background="#BB000000" Panel.ZIndex="9000"
                Visibility="Collapsed"
                MouseLeftButtonDown="itemInfoOverlay_Click">
            <Border x:Name="itemInfoCard"
                    Background="{DynamicResource Surface.Bg}"
                    BorderBrush="{DynamicResource Border.Primary}" BorderThickness="1"
                    CornerRadius="10" Padding="20"
                    MaxWidth="340" MaxHeight="460"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MouseLeftButtonDown="itemInfoCard_StopPropagation">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Direction="90"
                                      ShadowDepth="8" BlurRadius="20" Opacity="0.7"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock x:Name="itemInfoName"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Text.Primary}"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Button Content="&#x2715;" Click="itemInfoClose_Click"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="Transparent" Foreground="{DynamicResource Text.Secondary}"
                                BorderBrush="Transparent" FontSize="14"
                                Cursor="Hand" Padding="4,0,4,0"/>
                    </Grid>
                    <Image x:Name="itemInfoImage"
                           MaxHeight="200" Margin="0,0,0,12"
                           Stretch="Uniform" Visibility="Collapsed"/>
                    <TextBlock x:Name="itemInfoDesc"
                               Foreground="{DynamicResource Text.Label}" FontSize="12"
                               TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</Window>
